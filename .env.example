DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DATABASE?sslmode=require"
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SHOPIFY_APP_URL="https://your-app.example.com"
SCOPES="read_products,write_app_proxy"

# Resend email delivery.
EMAIL_FROM="Product Quotes <quotes@your-domain.example>"
RESEND_API_KEY=""

# 32+ random characters used only to encrypt per-store SMTP passwords at rest.
# Generate once for each deployment and keep it stable during key rotation.
EMAIL_CREDENTIALS_ENCRYPTION_KEY=""

# Private S3-compatible storage (AWS S3 or Cloudflare R2). In development,
# missing bucket configuration stores files under .data/private-uploads.
FILE_STORAGE_BUCKET=""
FILE_STORAGE_REGION="auto"
FILE_STORAGE_ENDPOINT=""
FILE_STORAGE_FORCE_PATH_STYLE="false"
FILE_STORAGE_ACCESS_KEY_ID=""
FILE_STORAGE_SECRET_ACCESS_KEY=""
